# Configuración del servidor
PORT=3000
PRICE_PER_HOUR=50

# Configuración de email (Gmail ejemplo)
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_app
EMAIL_FROM=Servicios Informáticos <tu_email@gmail.com>
EMAIL_TO=soporte@tuempresa.com

# Nombre de la empresa
COMPANY_NAME=Servicios Informáticos Profesionales

# ⚠️ CRÍTICO: Entorno
NODE_ENV=development

# Autenticación y Seguridad
# SESSION_SECRET debe tener al menos 32 caracteres en producción
SESSION_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Credenciales para setup inicial (eliminar después del uso)
# ADMIN_SETUP_PASSWORD=
# ROOT_SETUP_PASSWORD=