};

// Restore archived note
const restoreNote = (noteId) => {
    return new Promise((resolve, reject) => {
        const sql = `
            UPDATE notas 
            SET archivado = 0, fecha_archivado = NULL, usuario_archivado = NULL
            WHERE id = ?
        `;
        db.run(sql, [noteId], function (err) {
            if (err) {
                reject(err);
            } else {
                resolve({ changes: this.changes });
            }
        });
    });
};

