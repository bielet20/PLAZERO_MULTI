// ==================== CITAS / CALENDARIO ====================

const createAppointment = (appointmentData) => {
    return new Promise((resolve, reject) => {
        const { ticket_id, tecnico_id, fecha_cita, descripcion } = appointmentData;
        const sql = `
            INSERT INTO citas (ticket_id, tecnico_id, fecha_cita, descripcion)
            VALUES (?, ?, ?, ?)
        `;
        db.run(sql, [ticket_id, tecnico_id, fecha_cita, descripcion], function (err) {
            if (err) reject(err);
            else resolve({ id: this.lastID });
        });
    });
};

const getAppointmentsByTicket = (ticketId) => {
    return new Promise((resolve, reject) => {
        const sql = `
            SELECT c.*, u.nombre_completo as tecnico_nombre 
            FROM citas c
            JOIN usuarios u ON c.tecnico_id = u.id
            WHERE c.ticket_id = ?
            ORDER BY c.fecha_cita ASC
        `;
        db.all(sql, [ticketId], (err, rows) => {
            if (err) reject(err);
            else resolve(rows);
        });
    });
};

const getAppointmentsByTechnician = (tecnicoId) => {
    return new Promise((resolve, reject) => {
        const sql = `
            SELECT c.*, t.nombre as cliente_nombre, t.direccion, t.servicio
            FROM citas c
            JOIN tickets t ON c.ticket_id = t.ticket_id
            WHERE c.tecnico_id = ?
            ORDER BY c.fecha_cita ASC
        `;
        db.all(sql, [tecnicoId], (err, rows) => {
            if (err) reject(err);
            else resolve(rows);
        });
    });
};

const getAllAppointments = () => {
    return new Promise((resolve, reject) => {
        const sql = `
            SELECT c.*, u.nombre_completo as tecnico_nombre, t.nombre as cliente_nombre
            FROM citas c
            JOIN usuarios u ON c.tecnico_id = u.id
            JOIN tickets t ON c.ticket_id = t.ticket_id
            ORDER BY c.fecha_cita ASC
        `;
        db.all(sql, [], (err, rows) => {
            if (err) reject(err);
            else resolve(rows);
        });
    });
};

const updateAppointmentStatus = (id, estado) => {
    return new Promise((resolve, reject) => {
        const sql = 'UPDATE citas SET estado = ? WHERE id = ?';
        db.run(sql, [estado, id], function (err) {
            if (err) reject(err);
            else resolve({ changes: this.changes });
        });
    });
};

const deleteAppointment = (id) => {
    return new Promise((resolve, reject) => {
        const sql = 'DELETE FROM citas WHERE id = ?';
        db.run(sql, [id], function (err) {
            if (err) reject(err);
            else resolve({ changes: this.changes });
        });
    });
};

